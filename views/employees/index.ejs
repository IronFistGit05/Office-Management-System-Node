<!DOCTYPE html>
<html>
<head>
  <title>Employees</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>

<%- include("../partials/navbar") %>

<div class="container mt-4">

  <div class="d-flex justify-content-between mb-3">
    <h2>Employees</h2>
    <a href="/employees/new" class="btn btn-primary">+ Add Employee</a>
  </div>

  <form class="row mb-3" method="GET" action="/employees">
    <div class="col-md-4">
      <input class="form-control" name="search" placeholder="Search by name">
    </div>
    <div class="col-md-2">
      <button class="btn btn-dark">Search</button>
    </div>
  </form>

  <table class="table table-bordered table-hover">
    <thead class="table-dark">
      <tr>
        <th>Name</th>
        <th>Email</th>
        <th>Department</th>
        <th>Supervisor</th>
        <th>Actions</th>
      </tr>
    </thead>

    <tbody>
      <% employees.forEach(emp => { %>
        <tr>
          <td><%= emp.name %></td>
          <td><%= emp.email %></td>
          <td><%= emp.department?.name || "N/A" %></td>
          <td><%= emp.supervisor?.name || "None" %></td>

          <td>
            <a href="/employees/<%= emp._id %>/edit" class="btn btn-warning btn-sm">Edit</a>

            <form action="/employees/<%= emp._id %>?_method=DELETE" method="POST" style="display:inline;">
              <button class="btn btn-danger btn-sm">Delete</button>
            </form>
          </td>
        </tr>
      <% }) %>
    </tbody>

  </table>

</div>
</body>
</html>