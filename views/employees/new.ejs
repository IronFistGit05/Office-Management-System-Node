<!DOCTYPE html>
<html>
<head>
  <title>Add Employee</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>

<%- include("../partials/navbar") %>

<div class="container mt-4">
  <h2>Add Employee</h2>

  <form action="/employees" method="POST" class="row g-3">

    <div class="col-md-6">
      <input class="form-control" name="name" placeholder="Name" required>
    </div>

    <div class="col-md-6">
      <input class="form-control" name="email" placeholder="Email">
    </div>

    <div class="col-md-6">
      <input class="form-control" name="jobTitle" placeholder="Job Title">
    </div>

    <div class="col-md-6">
      <select class="form-select" name="department">
        <% departments.forEach(d => { %>
          <option value="<%= d._id %>"><%= d.name %></option>
        <% }) %>
      </select>
    </div>

    <div class="col-md-6">
      <select class="form-select" name="supervisor">
        <option value="">No Supervisor</option>
        <% employees.forEach(e => { %>
          <option value="<%= e._id %>"><%= e.name %></option>
        <% }) %>
      </select>
    </div>

    <div class="col-md-4">
      <select id="country" name="country" class="form-select"></select>
    </div>

    <div class="col-md-4">
      <select id="state" name="state" class="form-select"></select>
    </div>

    <div class="col-md-4">
      <select id="city" name="city" class="form-select"></select>
    </div>

    <div class="col-12">
      <button class="btn btn-success">Create Employee</button>
    </div>

  </form>
</div>

<!-- Country Script (same as before) -->
<script>
/* keep your existing country-state-city script here */
</script>

</body>
</html>